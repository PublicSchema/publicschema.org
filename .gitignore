# Python
__pycache__/
*.pyc
.venv/

# Build outputs
dist/

# Release snapshots (local until distribution strategy is decided)
releases/

# Generated files (built by build pipeline, copied to site/public)
site/public/*.csv
site/public/*.xlsx
site/public/*.schema.json
site/public/sp/
site/public/crvs/
site/public/schemas/
site/public/vocabulary.json
site/public/preview/

# Working documents (plans, research, reviews, reports, ideas)
.work/

# AI assistant config (local only)
CLAUDE.md
.claude/
.agents/
AGENTS.md

# Generated glossary (built by extract_glossary.py)
translations/glossary.yaml

# Generated external schema extractions
external/*/extracted/
# DHIS2 extracts are committed: the only source is a live demo server, so
# snapshotting them keeps the mapping reproducible offline.
!external/dhis2/extracted/

# Cloned external repos (large, fetched on demand)
external/semic/
external/*/repo/
external/*/repo-*/

# Node
node_modules/
site/dist/
site/.astro/
site/playwright-report/
site/test-results/
site/playwright.config.local.ts

# OS
.DS_Store

# Profile compiler paths (lives in publicschema-build, not here).
# Backstop in case someone accidentally re-creates these in this repo.
build/cel/
build/cli.py
build/generators/
build/profile.py
build/profile_compile.py
build/profile_validate.py
build/schemas/profile.schema.json
build/templates/
packages/
package.json
pnpm-lock.yaml
pnpm-workspace.yaml
scripts/publicschema
tests/fixtures/profiles/
tests/profile_pipeline/
build/preflight/_generated/
