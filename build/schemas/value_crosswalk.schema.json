{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://publicschema.com/schemas/subfile/value_crosswalk.schema.json",
  "title": "Value crosswalk subfile",
  "type": "object",
  "required": ["id", "source_value_set", "target_value_set", "pairs", "standard"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "source_value_set": { "type": "object" },
    "target_value_set": { "type": "object" },
    "pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_value", "target_value", "quality"],
        "additionalProperties": true
      }
    },
    "standard": {
      "type": "object",
      "required": ["source_id", "uri", "custodian", "license", "license_uri", "version", "attribution_text", "redistribution", "retrieved_at", "source_sha256"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
