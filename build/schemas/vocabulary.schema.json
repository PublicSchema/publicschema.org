{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://publicschema.org/schemas/vocabulary.schema.json",
  "title": "PublicSchema Vocabulary",
  "type": "object",
  "required": ["id", "maturity", "definition", "values"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "kebab-case vocabulary identifier"
    },
    "maturity": {
      "type": "string",
      "enum": ["draft", "trial-use", "normative"]
    },
    "definition": {
      "$ref": "#/$defs/multilingual_text"
    },
    "standard": {
      "type": ["object", "null"],
      "properties": {
        "name": { "type": "string" },
        "uri": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "values": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vocab_value"
      },
      "minItems": 1
    },
    "system_mappings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/system_mapping"
      }
    },
    "same_standard_systems": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sync": {
      "type": "object",
      "required": ["source_url", "format"],
      "additionalProperties": false,
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to download the authoritative standard data from"
        },
        "format": {
          "type": "string",
          "enum": ["fhir-codesystem", "iso-xml", "csv", "tsv", "semicolon-delimited", "github-json", "isco-json"],
          "description": "Parser to use for the downloaded data"
        },
        "last_synced": {
          "type": "string",
          "format": "date",
          "description": "Date of the most recent sync (ISO 8601)"
        }
      }
    }
  },
  "$defs": {
    "multilingual_text": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "system_mapping": {
      "type": "object",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "vocabulary_name": {
          "type": "string",
          "description": "Name the external system uses for this vocabulary"
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/system_mapping_value"
          },
          "minItems": 1
        },
        "unmapped_canonical": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical value codes not covered by this system"
        }
      }
    },
    "system_mapping_value": {
      "type": "object",
      "required": ["code", "label", "maps_to"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier used in the external system"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label the system uses"
        },
        "maps_to": {
          "type": ["string", "null"],
          "description": "Canonical value code, or null if no equivalent"
        }
      }
    },
    "vocab_value": {
      "type": "object",
      "required": ["code", "label"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": {
          "$ref": "#/$defs/multilingual_text"
        },
        "standard_code": {
          "type": "string"
        },
        "definition": {
          "$ref": "#/$defs/multilingual_text"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "description": "Depth in the hierarchy (1=top). Present only for hierarchical vocabularies."
        },
        "parent_code": {
          "type": "string",
          "description": "standard_code of the parent value in the hierarchy."
        }
      }
    }
  }
}
