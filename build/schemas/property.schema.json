{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://publicschema.org/schemas/property.schema.json",
  "title": "PublicSchema Property",
  "type": "object",
  "required": ["id", "maturity", "definition", "type", "cardinality"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "snake_case property identifier"
    },
    "maturity": {
      "type": "string",
      "enum": ["draft", "trial-use", "normative"]
    },
    "definition": {
      "$ref": "#/$defs/multilingual_text"
    },
    "type": {
      "type": "string",
      "pattern": "^(string|date|datetime|integer|decimal|boolean|uri|geojson_geometry|concept:[A-Z][a-zA-Z]*)$",
      "description": "One of: string, date, datetime, integer, decimal, boolean, uri, geojson_geometry, or concept:{ConceptId}"
    },
    "cardinality": {
      "type": "string",
      "enum": ["single", "multiple"]
    },
    "vocabulary": {
      "type": ["string", "null"],
      "description": "Reference to a vocabulary ID"
    },
    "references": {
      "type": ["string", "null"],
      "description": "Reference to a concept ID"
    },
    "domain_override": {
      "type": ["string", "null"],
      "description": "Explicit domain namespace override. Set to null to force universal URI, or to a domain code (e.g. 'sp') to force domain-specific URI, regardless of which concepts use this property."
    },
    "schema_org_equivalent": {
      "type": ["string", "null"],
      "pattern": "^schema:[a-zA-Z]+$",
      "description": "schema.org equivalent property as a CURIE (e.g. 'schema:givenName'). Used to generate camelCase aliases in the JSON-LD context."
    },
    "sensitivity": {
      "type": "string",
      "enum": ["standard", "sensitive", "restricted"],
      "description": "How sensitive this property is in most deployment contexts. standard (default, can be omitted): no special handling. sensitive: reveals circumstances (health, poverty, victimhood) in most contexts. restricted: should not appear in credentials at routine service points."
    },
    "system_mappings": {
      "type": ["object", "null"],
      "description": "Mappings showing how external system values correspond to this property's values",
      "additionalProperties": {
        "$ref": "#/$defs/system_mapping"
      }
    },
    "convergence": {
      "$ref": "#/$defs/convergence"
    }
  },
  "$defs": {
    "multilingual_text": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "convergence": {
      "type": "object",
      "properties": {
        "system_count": { "type": "integer", "minimum": 0 },
        "total_systems": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "system_mapping": {
      "type": "object",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "vocabulary_name": {
          "type": "string",
          "description": "Name the external system uses for this field or vocabulary"
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/system_mapping_value"
          },
          "minItems": 1
        },
        "unmapped_canonical": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical values not covered by this system"
        }
      }
    },
    "system_mapping_value": {
      "type": "object",
      "required": ["code", "label", "maps_to"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier used in the external system"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label the system uses"
        },
        "maps_to": {
          "type": ["string", "integer", "null"],
          "description": "Canonical property value, or null if no equivalent"
        },
        "unmapped_reason": {
          "type": "string",
          "enum": ["no_equivalent", "not_yet_mapped", "out_of_scope", "context_dependent"],
          "description": "Why this system value has no canonical equivalent. Required when maps_to is null."
        }
      }
    }
  }
}
