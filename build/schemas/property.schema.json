{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://publicschema.org/schemas/property.schema.json",
  "title": "PublicSchema Property",
  "type": "object",
  "required": ["id", "maturity", "definition", "type", "cardinality"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "snake_case property identifier"
    },
    "maturity": {
      "type": "string",
      "enum": ["draft", "trial-use", "normative"]
    },
    "definition": {
      "$ref": "#/$defs/multilingual_text"
    },
    "type": {
      "type": "string",
      "pattern": "^(string|date|datetime|integer|decimal|boolean|uri|geojson_geometry|concept:[A-Z][a-zA-Z]*)$",
      "description": "One of: string, date, datetime, integer, decimal, boolean, uri, geojson_geometry, or concept:{ConceptId}"
    },
    "cardinality": {
      "type": "string",
      "enum": ["single", "multiple"]
    },
    "vocabulary": {
      "type": ["string", "null"],
      "description": "Reference to a vocabulary ID"
    },
    "references": {
      "type": ["string", "null"],
      "description": "Reference to a concept ID"
    },
    "domain_override": {
      "type": ["string", "null"],
      "description": "Explicit domain namespace override. Set to null to force universal URI, or to a domain code (e.g. 'sp') to force domain-specific URI, regardless of which concepts use this property."
    },
    "schema_org_equivalent": {
      "type": ["string", "null"],
      "pattern": "^schema:[a-zA-Z]+$",
      "description": "schema.org equivalent property as a CURIE (e.g. 'schema:givenName'). Used to generate camelCase aliases in the JSON-LD context."
    },
    "sensitivity": {
      "type": "string",
      "enum": ["standard", "sensitive", "restricted"],
      "description": "How sensitive this property is in most deployment contexts. standard (default, can be omitted): no special handling. sensitive: reveals circumstances (health, poverty, victimhood) in most contexts. restricted: should not appear in credentials at routine service points."
    },
    "convergence": {
      "$ref": "#/$defs/convergence"
    }
  },
  "$defs": {
    "multilingual_text": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "convergence": {
      "type": "object",
      "properties": {
        "system_count": { "type": "integer", "minimum": 0 },
        "total_systems": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
