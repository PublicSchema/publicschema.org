---
import '../styles/global.css';
import { defaultLocale, languages, localesLive, type Locale } from '../i18n/languages';
import { localePath, switchLocalePath, useTranslations } from '../i18n/utils';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
  description?: string;
  alternateJsonLd?: string;
  ogType?: 'website' | 'article';
  locale?: Locale;
  noHreflang?: boolean;
}

const {
  title,
  alternateJsonLd,
  ogType = 'website',
  locale = defaultLocale,
  noHreflang = false,
} = Astro.props;

const t = useTranslations(locale);
const description = Astro.props.description ?? t('footer.tagline');

const currentPath = Astro.url.pathname;
const pageTitle = `${title} | PublicSchema`;
const canonicalUrl = new URL(currentPath, Astro.site).href;
const { htmlLang, ogLocale } = languages[locale];

// Build BreadcrumbList JSON-LD from the URL path segments.
// Strip locale prefix ('fr', 'es', etc.) and empty strings from the path.
const localeCodeSet = new Set(Object.keys(languages));
const rawSegments = currentPath.split('/').filter(Boolean);
const pathSegments = rawSegments[0] && localeCodeSet.has(rawSegments[0])
  ? rawSegments.slice(1)
  : rawSegments;

const breadcrumbItems: Array<{ '@type': string; position: number; name: string; item?: string }> = [
  { '@type': 'ListItem', position: 1, name: 'Home', item: new URL(localePath('/', locale), Astro.site).href },
];
pathSegments.forEach((segment, index) => {
  const isLast = index === pathSegments.length - 1;
  const segmentPath = '/' + pathSegments.slice(0, index + 1).join('/') + '/';
  const name = isLast ? title : segment.charAt(0).toUpperCase() + segment.slice(1);
  const item: { '@type': string; position: number; name: string; item?: string } = {
    '@type': 'ListItem',
    position: index + 2,
    name,
  };
  if (!isLast) {
    item.item = new URL(localePath(segmentPath, locale), Astro.site).href;
  }
  breadcrumbItems.push(item);
});

const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
});

const navLinks = [
  { href: '/concepts/', label: t('nav.concepts') },
  { href: '/vocab/', label: t('nav.vocabularies') },
  { href: '/docs/', label: t('nav.docs') },
  { href: '/about/', label: t('nav.about') },
];
---

<!doctype html>
<html lang={htmlLang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="canonical" href={canonicalUrl} />
  {!noHreflang && localesLive.map((loc) => (
    <link
      rel="alternate"
      hreflang={languages[loc].htmlLang}
      href={new URL(switchLocalePath(Astro.url, loc), Astro.site).href}
    />
  ))}
  {!noHreflang && <link rel="alternate" hreflang="x-default" href={new URL(switchLocalePath(Astro.url, defaultLocale), Astro.site).href} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#1e3a5f" />
  {alternateJsonLd && <link rel="alternate" type="application/ld+json" href={alternateJsonLd} />}
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-optimized site description" />

  <!-- OpenGraph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="PublicSchema" />
  <meta property="og:locale" content={ogLocale} />
  {!noHreflang && localesLive.filter((loc) => loc !== locale).map((loc) => (
    <meta property="og:locale:alternate" content={languages[loc].ogLocale} />
  ))}
  <meta property="og:image" content={new URL('/images/social-preview.png', Astro.site).href} />
  <meta property="og:image:alt" content="PublicSchema: common definitions for public service delivery" />
  <meta property="og:image:width" content="1280" />
  <meta property="og:image:height" content="640" />
  <meta property="og:logo" content={new URL('/images/logo.png', Astro.site).href} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={new URL('/images/social-preview.png', Astro.site).href} />
  <meta name="twitter:image:alt" content="PublicSchema: common definitions for public service delivery" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <!-- Hypothes.is annotation sidebar -->
  <script type="application/json" class="js-hypothesis-config">
    {
      "showHighlights": "whenSidebarOpen",
      "services": [{
        "authority": "hypothes.is",
        "allowLeavingGroups": true,
        "groups": ["6EELqkDo"]
      }],
      "branding": {
        "appBackgroundColor": "#faf9f6",
        "ctaBackgroundColor": "#1e3a5f",
        "ctaTextColor": "#ffffff",
        "selectionFontFamily": "'IBM Plex Sans', system-ui, sans-serif",
        "annotationFontFamily": "'IBM Plex Serif', Georgia, serif"
      }
    }
  </script>
  <script async src="https://hypothes.is/embed.js"></script>
</head>
<body>
  <a href="#main-content" class="skip-link">{t('nav.skip_to_content')}</a>
  <nav class="site-nav">
    <div class="site-container">
      <a href={localePath('/', locale)} class="site-logo">
        <img src="/images/logo.svg" alt="" class="logo-mark" width="32" height="32" />
        <span>
          <span class="site-title"><span class="site-title-public">Public</span>Schema</span>
          <span class="site-title-sub">Public Service Data Reference Model</span>
        </span>
      </a>
      <ul class="nav-links">
        {navLinks.map(({ href, label }) => {
          const localized = localePath(href, locale);
          return (
            <li>
              <a href={localized} class:list={[{ active: currentPath.startsWith(localized) }]}>
                {label}
              </a>
            </li>
          );
        })}
      </ul>
      <div
        class="search-container"
        data-locale={locale}
        data-search-placeholder={t('search.placeholder')}
        data-search-min-chars={t('search.min_chars')}
        data-search-no-results={t('search.no_results')}
        data-search-browse-hint={t('search.browse_hint')}
        data-search-results-status={t('search.results_status')}
        data-search-no-results-status={t('search.no_results_status')}
        data-nav-concepts={t('nav.concepts')}
        data-nav-properties={t('nav.properties')}
        data-nav-vocabularies={t('nav.vocabularies')}
        data-nav-docs={t('nav.docs')}
        data-search-close={t('search.close')}
      >
        <div class="search-input-wrapper">
          <input
            type="search"
            class="search-input"
            placeholder={t('search.placeholder')}
            role="combobox"
            aria-expanded="false"
            aria-autocomplete="list"
            aria-haspopup="listbox"
            aria-controls="search-results"
            aria-label={t('search.aria_label')}
            autocomplete="off"
            autocorrect="off"
            autocapitalize="none"
            spellcheck="false"
          />
          <kbd class="search-shortcut" aria-hidden="true"></kbd>
        </div>
        <div id="search-results" class="search-results" role="listbox" aria-label={t('search.aria_label')} hidden>
        </div>
        <span class="search-sr-status" aria-live="polite"></span>
      </div>
      <button class="search-mobile-toggle" aria-label={t('nav.search')} type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5"></circle>
          <line x1="13" y1="13" x2="18" y2="18"></line>
        </svg>
      </button>
      {localesLive.length > 1 && (
        <>
          <div class="lang-switcher-desktop-wrapper">
            <LanguageSwitcher currentLocale={locale} currentUrl={Astro.url} variant="desktop" />
          </div>
          <div class="lang-switcher-mobile-wrapper">
            <LanguageSwitcher currentLocale={locale} currentUrl={Astro.url} variant="mobile-compact" />
          </div>
        </>
      )}
      <details class="mobile-nav">
        <summary class="mobile-nav-toggle" aria-label={t('nav.menu')}>
          <span class="hamburger-icon"></span>
        </summary>
        <ul class="mobile-nav-links">
          {navLinks.map(({ href, label }) => {
            const localized = localePath(href, locale);
            return (
              <li>
                <a href={localized} class:list={[{ active: currentPath.startsWith(localized) }]}>
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
        {localesLive.length > 1 && (
          <LanguageSwitcher currentLocale={locale} currentUrl={Astro.url} variant="mobile-full" />
        )}
      </details>
    </div>
  </nav>

  <main id="main-content" class="site-container" tabindex="-1">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="footer-name">PublicSchema</div>
          <p>{t('footer.tagline')}</p>
        </div>
        <div class="footer-links">
          <div class="footer-links-col">
            <h4>{t('footer.explore')}</h4>
            <ul>
              <li><a href={localePath('/concepts/', locale)}>{t('nav.concepts')}</a></li>
              <li><a href={localePath('/properties/', locale)}>{t('nav.properties')}</a></li>
              <li><a href={localePath('/vocab/', locale)}>{t('nav.vocabularies')}</a></li>
              <li><a href={localePath('/systems/', locale)}>{t('footer.systems')}</a></li>
              <li><a href={localePath('/references/', locale)}>{t('footer.references')}</a></li>
            </ul>
          </div>
          <div class="footer-links-col">
            <h4>{t('footer.docs')}</h4>
            <ul>
              <li><a href={localePath('/docs/use-cases/', locale)}>{t('footer.use_cases')}</a></li>
              <li><a href={localePath('/docs/extension-mechanism/', locale)}>{t('footer.extension_mechanism')}</a></li>
              <li><a href={localePath('/docs/', locale)}>{t('footer.all_docs')}</a></li>
            </ul>
          </div>
          <div class="footer-links-col">
            <h4>{t('footer.project')}</h4>
            <ul>
              <li><a href={localePath('/about/', locale)}>{t('footer.about')}</a></li>
              <li><a href="https://github.com/PublicSchema/publicschema.org">{t('footer.source_github')}</a></li>
              <li><a href={localePath('/terms/', locale)}>{t('footer.terms')}</a></li>
              <li><a href="https://hypothes.is/groups/6EELqkDo/public-schema-review" target="_blank" rel="noopener noreferrer">{t('footer.join_review')}</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>{t('footer.reference_model_cc')} <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a> | {t('footer.code_apache')} <a href="https://www.apache.org/licenses/LICENSE-2.0">Apache 2.0</a></span>
        <span>{t('footer.built_with')} <a href="https://astro.build/">Astro</a></span>
      </div>
    </div>
  </footer>
  <button class="back-to-top" type="button" aria-label={t('nav.back_to_top')} hidden>
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="5,12 10,7 15,12"></polyline>
      <line x1="10" y1="7" x2="10" y2="16"></line>
    </svg>
  </button>
  <script src="../scripts/search.ts"></script>
  <script>
    const mobileNav = document.querySelector('.mobile-nav');
    if (mobileNav) {
      // Close menu when a link is clicked (handles same-page navigation)
      mobileNav.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => mobileNav.removeAttribute('open'));
      });
      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (mobileNav.hasAttribute('open') && !mobileNav.contains(e.target as Node)) {
          mobileNav.removeAttribute('open');
        }
      });
    }

    // Back-to-top: reveal after the user has scrolled past one viewport.
    const backToTop = document.querySelector<HTMLButtonElement>('.back-to-top');
    if (backToTop) {
      const toggle = () => {
        if (window.scrollY > window.innerHeight) {
          backToTop.hidden = false;
        } else {
          backToTop.hidden = true;
        }
      };
      toggle();
      window.addEventListener('scroll', toggle, { passive: true });
      backToTop.addEventListener('click', () => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
      });
    }
  </script>

  <style>
    .lang-switcher-desktop-wrapper {
      display: flex;
      align-items: center;
      padding-left: var(--space-sm);
      border-left: 1px solid var(--color-border-light);
    }
    .lang-switcher-mobile-wrapper {
      display: none;
    }

    @media (max-width: 900px) {
      .lang-switcher-desktop-wrapper {
        display: none;
      }
      .lang-switcher-mobile-wrapper {
        display: flex;
        align-items: center;
        margin-right: 0.25rem;
      }
    }
  </style>
</body>
</html>
