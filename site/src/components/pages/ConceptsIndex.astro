---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { loadVocabulary } from '../../data/vocabulary';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const vocab = loadVocabulary();
const maturityRank: Record<string, number> = { normative: 0, "trial-use": 1, draft: 2 };
const byMaturityThenName = (a: { maturity: string; id: string }, b: { maturity: string; id: string }) =>
  (maturityRank[a.maturity] ?? 9) - (maturityRank[b.maturity] ?? 9) || a.id.localeCompare(b.id);
const concepts = Object.values(vocab.concepts).sort(byMaturityThenName);
const coreConcepts = concepts.filter((c) => !c.domain);
const domainLabels: Record<string, string> = { sp: t('concepts.section_social_protection') };
const domainCodes = [...new Set(concepts.filter((c) => c.domain).map((c) => c.domain as string))].sort();
const conceptsByDomain = Object.fromEntries(domainCodes.map((d) => [d, concepts.filter((c) => c.domain === d)]));
---
<Base title={t('concepts.page_title')} description={t('concepts.page_subtitle')} locale={locale}>
  <div class="page-header">
    <nav class="breadcrumb">
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{t('common.concepts')}
    </nav>
    <h1>{t('concepts.page_title')}</h1>
    <p class="subtitle">{t('concepts.page_subtitle')}</p>
  </div>

  <h2>{t('concepts.section_core')}</h2>
  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>{t('concepts.table.concept')}</th>
        <th>{t('concepts.table.definition')}</th>
      </tr>
    </thead>
    <tbody>
      {coreConcepts.map((c) => (
        <tr>
          <td><a href={localePath(c.path, locale)}>{c.id}</a></td>
          <td data-label={t('concepts.table.definition')}>{(c.definition[locale] ?? c.definition.en)?.slice(0, 100)}{((c.definition[locale] ?? c.definition.en)?.length || 0) > 100 ? "..." : ""}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {domainCodes.map((domain) => (
    <Fragment>
      <h2>{domainLabels[domain] || domain}</h2>
      <table class="data-table mobile-card-table">
        <thead>
          <tr>
            <th>{t('concepts.table.concept')}</th>
            <th>{t('concepts.table.definition')}</th>
          </tr>
        </thead>
        <tbody>
          {conceptsByDomain[domain].map((c) => (
            <tr>
              <td><a href={localePath(c.path, locale)}>{c.id}</a></td>
              <td data-label={t('concepts.table.definition')}>{(c.definition[locale] ?? c.definition.en)?.slice(0, 100)}{((c.definition[locale] ?? c.definition.en)?.length || 0) > 100 ? "..." : ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </Fragment>
  ))}
</Base>
