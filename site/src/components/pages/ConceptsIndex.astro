---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { loadVocabulary } from '../../data/vocabulary';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const vocab = loadVocabulary();

// Order: universal first, then sp, then crvs; alphabetical within.
const domainOrder: Record<string, number> = { '': 0, sp: 1, crvs: 2 };
const concepts = Object.values(vocab.concepts).sort((a, b) => {
  const da = domainOrder[a.domain ?? ''] ?? 99;
  const db = domainOrder[b.domain ?? ''] ?? 99;
  if (da !== db) return da - db;
  return a.id.localeCompare(b.id);
});

const totalCount = concepts.length;

// Systems present in concept-level external_equivalents.
const knownSystems = [
  'dci', 'fhir', 'fhir-r4', 'fhir-r5', 'opencrvs', 'semic',
  'schema-org', 'foaf', 'prov', 'dpv', 'dpv-consent-notice', 'icao',
];
const allSystems: string[] = knownSystems.filter((sys) =>
  concepts.some((c) => Object.keys(c.external_equivalents ?? {}).includes(sys))
);

const conceptLabel = (c: { id: string; label?: { en?: string; fr?: string; es?: string } }) =>
  c.label?.[locale] ?? c.label?.en ?? c.id;
const conceptDef = (c: { definition?: { en?: string; fr?: string; es?: string } }) =>
  c.definition?.[locale] ?? c.definition?.en ?? '';
---
<Base title={t('concepts.page_title')} description={t('concepts.page_subtitle')} locale={locale}>
  <div class="faceted-page">
    <nav class="breadcrumb" aria-label={t('breadcrumb.home')}>
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{t('common.concepts')}
    </nav>

    <header class="page-header">
      <h1>{t('concepts.page_title')}</h1>
      <p class="intro">{t('concepts.browse_intro', { count: totalCount })}</p>
    </header>

    <div class="layout">
      <aside class="facet-panel">
        <details class="facet-drawer" open>
          <summary class="facet-drawer-toggle">
            {t('browse.filters')}
            <span class="active-badge" id="active-count" aria-live="polite"></span>
          </summary>

          <div class="facet-content">
            <button class="clear-btn" id="clear-all" type="button">{t('browse.clear_all')}</button>

            <fieldset class="facet-group">
              <legend>{t('browse.facet_domain')}</legend>
              <label><input type="checkbox" name="domain" value="root"> {t('browse.domain_universal')}</label>
              <label><input type="checkbox" name="domain" value="sp"> {t('browse.domain_sp')}</label>
              <label><input type="checkbox" name="domain" value="crvs"> {t('browse.domain_crvs')}</label>
            </fieldset>

            <fieldset class="facet-group">
              <legend>{t('browse.facet_maturity')}</legend>
              <label><input type="checkbox" name="maturity" value="draft"> {t('browse.maturity_draft')}</label>
              <label><input type="checkbox" name="maturity" value="candidate"> {t('browse.maturity_candidate')}</label>
              <label><input type="checkbox" name="maturity" value="normative"> {t('browse.maturity_normative')}</label>
            </fieldset>

            <fieldset class="facet-group">
              <legend>{t('browse.facet_abstract')}</legend>
              <label><input type="checkbox" name="abstract" value="yes"> {t('browse.yes')}</label>
              <label><input type="checkbox" name="abstract" value="no"> {t('browse.no')}</label>
            </fieldset>

            {allSystems.length > 0 && (
              <fieldset class="facet-group">
                <legend>{t('browse.facet_mapping')}</legend>
                {allSystems.map((sys) => (
                  <label><input type="checkbox" name="system" value={sys}> {sys}</label>
                ))}
              </fieldset>
            )}
          </div>
        </details>
      </aside>

      <main class="results-area">
        <div class="results-toolbar">
          <div class="search-wrap">
            <label for="concept-search" class="sr-only">{t('browse.search_placeholder')}</label>
            <input
              type="search"
              id="concept-search"
              placeholder={t('browse.search_placeholder')}
              autocomplete="off"
            />
          </div>
          <p class="result-count" id="result-count" data-showing-template={t('browse.showing', { visible: '__V__', total: totalCount })} aria-live="polite" aria-atomic="true">
            {t('browse.showing', { visible: totalCount, total: totalCount })}
          </p>
        </div>

        <div class="card-grid" id="card-grid">
          {concepts.map((c) => {
            const domainVal = c.domain ?? 'root';
            const systems = Object.keys(c.external_equivalents ?? {});
            const defFull = conceptDef(c).replace(/\n/g, ' ');
            const defSnippet = defFull.slice(0, 150);
            const defDisplay = defSnippet.length === 150 ? defSnippet + '…' : defSnippet;
            const href = c.path.endsWith('/') ? c.path : c.path + '/';
            return (
              <a
                href={localePath(href, locale)}
                class="concept-card"
                data-id={c.id.toLowerCase()}
                data-label={conceptLabel(c).toLowerCase()}
                data-definition={defFull.toLowerCase()}
                data-domain={domainVal}
                data-maturity={c.maturity}
                data-abstract={c.abstract ? 'yes' : 'no'}
                data-systems={systems.join(',')}
              >
                <div class="card-header">
                  <span class="concept-label">{conceptLabel(c)}</span>
                  <div class="badges">
                    {domainVal !== 'root' && (
                      <span class={`badge badge-domain badge-domain-${domainVal}`}>
                        {c.domain}
                      </span>
                    )}
                    <span class={`badge badge-maturity badge-maturity-${c.maturity}`}>
                      {t(`browse.maturity_${c.maturity}`)}
                    </span>
                    {c.abstract && <span class="badge badge-abstract">{t('browse.facet_abstract').toLowerCase()}</span>}
                  </div>
                </div>
                <p class="card-id">{c.id}</p>
                {defDisplay && <p class="card-def">{defDisplay}</p>}
                <div class="card-footer">
                  <span class="prop-count">{t('browse.prop_count', { count: c.properties?.length ?? 0 })}</span>
                  {systems.length > 0 && (
                    <div class="system-chips">
                      {systems.map((sys) => (
                        <span class="chip">{sys}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>

        <p class="no-results" id="no-results" hidden>
          {t('browse.no_results')} <button type="button" id="clear-all-2">{t('browse.clear_filters_link')}</button>
        </p>
      </main>
    </div>
  </div>
</Base>

<style>
  .faceted-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 0.5rem;
  }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .separator { margin: 0 0.3rem; }

  .page-header {
    margin-bottom: 1.5rem;
  }
  .page-header h1 {
    font-size: 1.8rem;
    margin: 0 0 0.4rem;
  }
  .intro {
    color: #555;
    margin: 0;
    max-width: 65ch;
  }

  .layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .facet-panel {
    flex: 0 0 220px;
    min-width: 180px;
  }

  .facet-drawer {
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fafafa;
    overflow: hidden;
    position: sticky;
    top: 1rem;
  }

  .facet-drawer-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    list-style: none;
    background: #f0f0f0;
    border-bottom: 1px solid #ddd;
    user-select: none;
  }
  .facet-drawer-toggle::-webkit-details-marker { display: none; }

  .facet-content {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .clear-btn {
    font-size: 0.8rem;
    background: none;
    border: 1px solid #bbb;
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    align-self: flex-start;
    color: #444;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .clear-btn:hover { background: #eee; }
  .clear-btn:focus-visible { outline: 2px solid #2563eb; outline-offset: 2px; }

  .facet-group {
    border: none;
    padding: 0;
    margin: 0;
  }
  .facet-group legend {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #777;
    margin-bottom: 0.35rem;
  }
  .facet-group label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    padding: 0.3rem 0;
    cursor: pointer;
    color: #333;
    min-height: 44px;
  }
  .facet-group input[type="checkbox"] {
    accent-color: #2563eb;
    cursor: pointer;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .active-badge {
    background: #2563eb;
    color: #fff;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.05rem 0.4rem;
    min-width: 1.2rem;
    text-align: center;
  }
  .active-badge:empty { display: none; }

  .results-area {
    flex: 1;
    min-width: 0;
  }

  .results-toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .search-wrap {
    flex: 1;
    min-width: 200px;
  }

  #concept-search {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 0.9rem;
    box-sizing: border-box;
  }
  #concept-search:focus {
    outline: 2px solid #2563eb;
    border-color: #2563eb;
  }

  .result-count {
    font-size: 0.85rem;
    color: #666;
    white-space: nowrap;
    margin: 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.9rem;
  }

  .concept-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.9rem 1rem;
    border: 1px solid #dde;
    border-radius: 8px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .concept-card[hidden] { display: none; }

  .concept-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .concept-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: #111;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .badge-domain-sp   { background: #dbeafe; color: #1d4ed8; }
  .badge-domain-crvs { background: #ede9fe; color: #6d28d9; }

  .badge-maturity-draft     { background: #fef9c3; color: #854d0e; }
  .badge-maturity-candidate { background: #ffedd5; color: #9a3412; }
  .badge-maturity-normative { background: #dcfce7; color: #166534; }

  .badge-abstract { background: #f1f5f9; color: #475569; }

  .card-id {
    font-size: 0.75rem;
    color: #888;
    margin: 0;
    font-family: monospace;
  }

  .card-def {
    font-size: 0.82rem;
    color: #444;
    margin: 0;
    line-height: 1.45;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .prop-count {
    font-size: 0.75rem;
    color: #777;
    white-space: nowrap;
  }

  .system-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
  }

  .chip {
    font-size: 0.65rem;
    background: #f0f4ff;
    color: #3b5bdb;
    border: 1px solid #c5d0fa;
    border-radius: 3px;
    padding: 0.05rem 0.3rem;
    font-weight: 600;
    font-family: monospace;
  }

  .no-results {
    text-align: center;
    color: #777;
    margin-top: 3rem;
    font-size: 0.9rem;
  }

  .no-results button {
    background: none;
    border: none;
    color: #2563eb;
    cursor: pointer;
    text-decoration: underline;
    font-size: inherit;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 700px) {
    .layout {
      flex-direction: column;
    }
    .facet-panel {
      flex: unset;
      width: 100%;
    }
    .facet-drawer {
      position: static;
    }
    .facet-drawer:not([open]) .facet-content {
      display: none;
    }
    /* Visible chevron arrow so users know the panel is toggleable */
    .facet-drawer-toggle::after {
      content: '▸';
      margin-left: auto;
      font-size: 0.8rem;
      transition: transform 0.2s;
    }
    .facet-drawer[open] > .facet-drawer-toggle::after {
      content: '▾';
    }
    /* Increase toggle tap height */
    .facet-drawer-toggle {
      min-height: 44px;
    }
    /* Grid: single column at narrow viewports */
    .card-grid {
      grid-template-columns: 1fr;
    }
    /* Result count can wrap under the search box */
    .result-count {
      white-space: normal;
    }
  }

  @media (min-width: 701px) {
    .facet-drawer-toggle {
      pointer-events: none;
    }
    .facet-drawer[open] > .facet-drawer-toggle::after {
      content: '';
    }
  }
</style>

<script>
  (() => {
    // Close the filter drawer by default on mobile; keep open on desktop.
    const drawer = document.querySelector<HTMLDetailsElement>('.facet-drawer');
    if (drawer && window.innerWidth <= 700) {
      drawer.removeAttribute('open');
    }

    const grid = document.getElementById('card-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.concept-card'));
    const searchInput = document.getElementById('concept-search') as HTMLInputElement;
    const resultCountEl = document.getElementById('result-count')!;
    const activeCountEl = document.getElementById('active-count')!;
    const noResults = document.getElementById('no-results')!;
    const total = cards.length;
    const showingTpl = resultCountEl.dataset.showingTemplate ?? 'Showing __V__ of ' + total;

    const domainBoxes   = document.querySelectorAll<HTMLInputElement>('input[name="domain"]');
    const maturityBoxes = document.querySelectorAll<HTMLInputElement>('input[name="maturity"]');
    const abstractBoxes = document.querySelectorAll<HTMLInputElement>('input[name="abstract"]');
    const systemBoxes   = document.querySelectorAll<HTMLInputElement>('input[name="system"]');

    function getParam(key: string): string[] {
      return new URLSearchParams(location.search).getAll(key);
    }

    function buildQueryString(): string {
      const p = new URLSearchParams();
      domainBoxes.forEach((cb) => { if (cb.checked) p.append('domain', cb.value); });
      maturityBoxes.forEach((cb) => { if (cb.checked) p.append('maturity', cb.value); });
      abstractBoxes.forEach((cb) => { if (cb.checked) p.append('abstract', cb.value); });
      systemBoxes.forEach((cb) => { if (cb.checked) p.append('system', cb.value); });
      const q = searchInput.value.trim();
      if (q) p.set('q', q);
      return p.toString();
    }

    function initFromUrl() {
      const domains    = getParam('domain');
      const maturities = getParam('maturity');
      const abstracts  = getParam('abstract');
      const systems    = getParam('system');
      const q          = new URLSearchParams(location.search).get('q') ?? '';

      domainBoxes.forEach((cb) => { cb.checked = domains.includes(cb.value); });
      maturityBoxes.forEach((cb) => { cb.checked = maturities.includes(cb.value); });
      abstractBoxes.forEach((cb) => { cb.checked = abstracts.includes(cb.value); });
      systemBoxes.forEach((cb) => { cb.checked = systems.includes(cb.value); });
      searchInput.value = q;
    }

    function checkedValues(boxes: NodeListOf<HTMLInputElement>): string[] {
      return Array.from(boxes).filter((cb) => cb.checked).map((cb) => cb.value);
    }

    function applyFilters() {
      const domains    = checkedValues(domainBoxes);
      const maturities = checkedValues(maturityBoxes);
      const abstracts  = checkedValues(abstractBoxes);
      const systems    = checkedValues(systemBoxes);
      const query      = searchInput.value.trim().toLowerCase();

      let visible = 0;

      cards.forEach((card) => {
        const cardDomain   = card.dataset.domain!;
        const cardMaturity = card.dataset.maturity!;
        const cardAbstract = card.dataset.abstract!;
        const cardSystems  = card.dataset.systems ? card.dataset.systems.split(',') : [];

        const matchDomain   = domains.length === 0 || domains.includes(cardDomain);
        const matchMaturity = maturities.length === 0 || maturities.includes(cardMaturity);
        const matchAbstract = abstracts.length === 0 || abstracts.includes(cardAbstract);
        const matchSystem   = systems.length === 0 || systems.some((s) => cardSystems.includes(s));
        const matchQuery    = !query || [
          card.dataset.id ?? '',
          card.dataset.label ?? '',
          card.dataset.definition ?? '',
        ].some((field) => field.includes(query));

        const show = matchDomain && matchMaturity && matchAbstract && matchSystem && matchQuery;
        card.hidden = !show;
        if (show) visible++;
      });

      resultCountEl.textContent = showingTpl.replace('__V__', String(visible));
      noResults.hidden = visible > 0;

      const activeCount = domains.length + maturities.length + abstracts.length + systems.length + (query ? 1 : 0);
      activeCountEl.textContent = activeCount > 0 ? String(activeCount) : '';

      const qs = buildQueryString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    function clearAll() {
      domainBoxes.forEach((cb) => { cb.checked = false; });
      maturityBoxes.forEach((cb) => { cb.checked = false; });
      abstractBoxes.forEach((cb) => { cb.checked = false; });
      systemBoxes.forEach((cb) => { cb.checked = false; });
      searchInput.value = '';
      applyFilters();
    }

    document.getElementById('clear-all')!.addEventListener('click', clearAll);
    document.getElementById('clear-all-2')!.addEventListener('click', clearAll);

    domainBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    maturityBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    abstractBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    systemBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    searchInput.addEventListener('input', applyFilters);

    initFromUrl();
    applyFilters();
  })();
</script>
</Base>
