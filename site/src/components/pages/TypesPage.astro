---
import Base from '../../layouts/Base.astro';
import TranslationBanner from '../TranslationBanner.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { localePath, useTranslations } from '../../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const modules = import.meta.glob('./content/TypesContent.*.astro');
const wantedKey = `./content/TypesContent.${locale}.astro`;
const fallbackKey = './content/TypesContent.en.astro';
const loader = modules[wantedKey] ?? modules[fallbackKey];
const fellBack = !modules[wantedKey];
const Content = (await loader()).default;

const headers: Record<Locale, { title: string; subtitle: string; description: string }> = {
  en: {
    title: 'Data Types',
    subtitle: 'The data types used by properties in the vocabulary.',
    description: 'Primitive data types used by PublicSchema properties.',
  },
  fr: {
    title: 'Types de données',
    subtitle: 'Les types de données utilisés par les propriétés du vocabulaire.',
    description: 'Types de données primitifs utilisés par les propriétés de PublicSchema.',
  },
  es: {
    title: 'Tipos de datos',
    subtitle: 'Los tipos de datos utilizados por las propiedades del vocabulario.',
    description: 'Tipos de datos primitivos utilizados por las propiedades de PublicSchema.',
  },
};

const { title, subtitle, description } = headers[locale];
---
<Base title={title} description={description} locale={locale}>
  <article class="concept-narrative">
    {fellBack && <TranslationBanner locale={locale} />}
    <div class="page-header">
      <nav class="breadcrumb" aria-label={t('breadcrumb.home')}>
        <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{title}
      </nav>
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
    </div>
    <Content />
  </article>
</Base>
