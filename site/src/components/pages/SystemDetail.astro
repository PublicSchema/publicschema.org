---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { buildSystemIndex, getSystemMeta, getIssueUrl } from '../../data/systems';

interface Props {
  system: string;
  locale?: Locale;
}

const { system: systemId, locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const index = buildSystemIndex();
const entries = index[systemId] ?? [];
const meta = getSystemMeta(systemId);
const issueUrl = getIssueUrl(meta.name);

const vocabEntries = entries.filter((e) => e.kind === "vocabulary");
const propEntries = entries.filter((e) => e.kind === "property");
const valueMapped = vocabEntries.filter((e) => e.relationship === "value_mapping").length;
const sameStandard = vocabEntries.filter((e) => e.relationship === "same_standard").length;
---
<Base title={meta.name} description={`Vocabulary mappings between ${meta.name} and PublicSchema.`} locale={locale}>
  <article>
  <div class="page-header">
    <nav class="breadcrumb">
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a>
      <span class="separator">/</span>
      <a href={localePath('/systems/', locale)}>{t('common.systems')}</a>
      <span class="separator">/</span>
      {meta.name}
    </nav>
    <h1>
      {meta.name}
      <span class={`badge badge-${meta.reviewStatus}`}>{meta.reviewStatus}</span>
    </h1>
    {meta.url && (
      <p><a href={meta.url} target="_blank" rel="noopener">{meta.url}</a></p>
    )}
    <p class="definition-text">{meta.description}</p>
    {meta.reviewStatus === "reviewed" && meta.lastReviewed && (
      <p style="color: var(--color-text-muted); font-size: 0.85rem;">
        Last reviewed: {meta.lastReviewed}{meta.reviewedBy ? ` by ${meta.reviewedBy}` : ""}
      </p>
    )}
  </div>

  <div class="concept-section">
    <p>
      This page shows how {meta.name} vocabulary codes map to PublicSchema canonical values.
      If you work with {meta.name} and spot an error, please <a href={issueUrl} target="_blank" rel="noopener">report it</a>.
    </p>
    <p style="color: var(--color-text-muted); font-size: 0.85rem;">
      {vocabEntries.length} {t('system_detail.vocabularies').toLowerCase()} covered: {valueMapped} {t('system_detail.relationship_value_mapping').toLowerCase()}{sameStandard > 0 ? `, ${sameStandard} ${t('system_detail.relationship_same_standard').toLowerCase()}` : ""}.
      {propEntries.length > 0 && ` ${propEntries.length} property mapping${propEntries.length > 1 ? "s" : ""}.`}
    </p>
  </div>

  {vocabEntries.length > 0 && (
  <div class="concept-section">
    <h2>{t('system_detail.vocabularies')}</h2>
    <table class="data-table mobile-card-table">
      <thead>
        <tr>
          <th>{t('system_detail.table.vocabulary')}</th>
          <th>{t('system_detail.table.system_name')}</th>
          <th>{t('system_detail.table.relationship')}</th>
          <th>{t('system_detail.table.coverage')}</th>
          <th>{t('system_detail.table.gaps')}</th>
        </tr>
      </thead>
      <tbody>
        {vocabEntries.map((entry) => (
          <tr>
            <td><a href={localePath(`/vocab/${entry.vocabId}#${systemId}`, locale)}>{entry.vocabId}</a></td>
            <td data-label={t('system_detail.table.system_name')}>{entry.vocabularyName ?? ""}</td>
            <td data-label={t('system_detail.table.relationship')}>
              {entry.relationship === "same_standard" ? t('system_detail.relationship_same_standard') : t('system_detail.relationship_value_mapping')}
            </td>
            <td data-label={t('system_detail.table.coverage')}>
              {entry.relationship === "same_standard"
                ? t('system_detail.coverage_all')
                : t('system_detail.coverage_mapped', { mapped: entry.mappedCount, total: entry.totalSystemValues })}
            </td>
            <td data-label={t('system_detail.table.gaps')}>
              {entry.unmappedCanonicalCount > 0
                ? t('system_detail.not_covered', { count: entry.unmappedCanonicalCount })
                : ""}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  )}

  {propEntries.length > 0 && (
  <div class="concept-section">
    <h2>{t('system_detail.properties')}</h2>
    <table class="data-table mobile-card-table">
      <thead>
        <tr>
          <th>{t('system_detail.table.vocabulary')}</th>
          <th>{t('system_detail.table.system_name')}</th>
          <th>{t('system_detail.table.coverage')}</th>
          <th>{t('system_detail.table.gaps')}</th>
        </tr>
      </thead>
      <tbody>
        {propEntries.map((entry) => (
          <tr>
            <td><a href={localePath(`/${entry.vocabId}`, locale)}>{entry.vocabId}</a></td>
            <td data-label={t('system_detail.table.system_name')}>{entry.vocabularyName ?? ""}</td>
            <td data-label={t('system_detail.table.coverage')}>{t('system_detail.coverage_mapped', { mapped: entry.mappedCount, total: entry.totalSystemValues })}</td>
            <td data-label={t('system_detail.table.gaps')}>
              {entry.unmappedCanonicalCount > 0
                ? t('system_detail.not_covered', { count: entry.unmappedCanonicalCount })
                : ""}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  )}

  <div class="concept-section" style="text-align: center;">
    <a href={issueUrl} target="_blank" rel="noopener" class="btn btn-secondary">
      {t('system_detail.report_button')}
    </a>
  </div>
  </article>
</Base>
