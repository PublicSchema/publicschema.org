---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { docs } from '../../data/docs';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

interface DocLink {
  slug: string;
  title: string;
  description: string;
}

interface DocCategory {
  name: string;
  docs: DocLink[];
}

// Group docs by category, preserving insertion order
const categoryOrder = ["Getting Started", "Technical Documentation", "Landscape"];
const grouped = new Map<string, DocLink[]>();
for (const name of categoryOrder) {
  grouped.set(name, []);
}
for (const [slug, entry] of Object.entries(docs)) {
  const list = grouped.get(entry.category);
  if (list) list.push({ slug, title: entry.title, description: entry.description });
}
const categories: DocCategory[] = categoryOrder.map((name) => ({
  name,
  docs: grouped.get(name)!,
}));
---
<Base title={t('docs.page_title')} description={t('docs.page_subtitle')} locale={locale}>
  <div class="page-header">
    <h1>{t('docs.page_title')}</h1>
    <p class="subtitle">{t('docs.page_subtitle')}</p>
  </div>

  {categories.map((cat) => (
    <section class="doc-category">
      <h2>{cat.name}</h2>
      <div class="doc-list">
        {cat.docs.map((doc) => (
          <a href={localePath(`/docs/${doc.slug}/`, locale)} class="doc-card">
            <h3>{doc.title}</h3>
            <p>{doc.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>
