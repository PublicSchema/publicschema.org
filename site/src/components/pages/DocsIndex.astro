---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { docs, type DocCategoryKey } from '../../data/docs';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

interface DocLink {
  slug: string;
  title: string;
  description: string;
}

interface DocCategory {
  name: string;
  docs: DocLink[];
}

// Group docs by category, preserving insertion order
const categoryOrder: DocCategoryKey[] = ['getting_started', 'technical', 'landscape'];
const categoryLabelKey: Record<DocCategoryKey, string> = {
  getting_started: 'docs.category.getting_started',
  technical: 'docs.category.technical',
  landscape: 'docs.category.landscape',
};
const grouped = new Map<DocCategoryKey, DocLink[]>();
for (const key of categoryOrder) {
  grouped.set(key, []);
}
for (const [slug, entry] of Object.entries(docs)) {
  const list = grouped.get(entry.category);
  if (list) {
    list.push({
      slug,
      title: entry.title[locale] ?? entry.title.en,
      description: entry.description[locale] ?? entry.description.en,
    });
  }
}
const categories: DocCategory[] = categoryOrder.map((key) => ({
  name: t(categoryLabelKey[key]),
  docs: grouped.get(key)!,
}));
---
<Base title={t('docs.page_title')} description={t('docs.page_subtitle')} locale={locale}>
  <div class="page-header">
    <nav class="breadcrumb" aria-label={t('breadcrumb.home')}>
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{t('nav.docs')}
    </nav>
    <h1>{t('docs.page_title')}</h1>
    <p class="subtitle">{t('docs.page_subtitle')}</p>
  </div>

  {categories.map((cat) => (
    <section class="doc-category">
      <h2>{cat.name}</h2>
      <div class="doc-list">
        {cat.docs.map((doc) => (
          <a href={localePath(`/docs/${doc.slug}/`, locale)} class="doc-card">
            <h3>{doc.title}</h3>
            <p>{doc.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>
