---
import Base from "../../layouts/Base.astro";
import { loadVocabulary } from "../../data/vocabulary";

const vocab = loadVocabulary();
const maturityRank: Record<string, number> = { normative: 0, "trial-use": 1, draft: 2 };
const byMaturityThenName = (a: { maturity: string; id: string }, b: { maturity: string; id: string }) =>
  (maturityRank[a.maturity] ?? 9) - (maturityRank[b.maturity] ?? 9) || a.id.localeCompare(b.id);
const concepts = Object.values(vocab.concepts).sort(byMaturityThenName);
const coreConcepts = concepts.filter((c) => !c.domain);
const domainLabels: Record<string, string> = { sp: "Social Protection" };
const domainCodes = [...new Set(concepts.filter((c) => c.domain).map((c) => c.domain as string))].sort();
const conceptsByDomain = Object.fromEntries(domainCodes.map((d) => [d, concepts.filter((c) => c.domain === d)]));
---
<Base title="Concepts" description="All concepts in the PublicSchema vocabulary.">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="separator">/</span>Concepts
    </nav>
    <h1>Concepts</h1>
    <p class="subtitle">The core entities that appear across public service delivery systems.</p>
  </div>

  <h2>Core</h2>
  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>Concept</th>
        <th>Definition</th>
        <th>Maturity</th>
      </tr>
    </thead>
    <tbody>
      {coreConcepts.map((c) => (
        <tr>
          <td><a href={c.path}>{c.id}</a></td>
          <td data-label="Definition">{c.definition.en?.slice(0, 100)}{(c.definition.en?.length || 0) > 100 ? "..." : ""}</td>
          <td data-label="Maturity"><span class={`badge badge-${c.maturity}`}>{c.maturity}</span></td>
        </tr>
      ))}
    </tbody>
  </table>

  {domainCodes.map((domain) => (
    <Fragment>
      <h2>{domainLabels[domain] || domain}</h2>
      <table class="data-table mobile-card-table">
        <thead>
          <tr>
            <th>Concept</th>
            <th>Definition</th>
            <th>Maturity</th>
          </tr>
        </thead>
        <tbody>
          {conceptsByDomain[domain].map((c) => (
            <tr>
              <td><a href={c.path}>{c.id}</a></td>
              <td data-label="Definition">{c.definition.en?.slice(0, 100)}{(c.definition.en?.length || 0) > 100 ? "..." : ""}</td>
              <td data-label="Maturity"><span class={`badge badge-${c.maturity}`}>{c.maturity}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </Fragment>
  ))}
</Base>
