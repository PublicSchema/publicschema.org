---
// @ts-ignore
import vocab from '../../../../dist/vocabulary.json';
import Base from '../../layouts/Base.astro';

type ConceptEntry = {
  id: string;
  domain: string | null;
  path: string;
  maturity: string;
  abstract: boolean;
  featured: boolean;
  label: { en: string; fr?: string; es?: string };
  definition: { en?: string; fr?: string; es?: string };
  properties: { id: string }[];
  external_equivalents: Record<string, unknown> | null;
};

const conceptsMap: Record<string, ConceptEntry> = (vocab as any).concepts;

// Build a sorted list: root first, then sp, then crvs; alphabetical within each group.
const domainOrder: Record<string, number> = { '': 0, sp: 1, crvs: 2 };

const concepts = Object.values(conceptsMap).sort((a, b) => {
  const da = domainOrder[a.domain ?? ''] ?? 99;
  const db = domainOrder[b.domain ?? ''] ?? 99;
  if (da !== db) return da - db;
  return a.id.localeCompare(b.id);
});

const totalCount = concepts.length;

// Collect all systems present in the data.
const allSystems: string[] = [
  'dci', 'fhir', 'fhir-r4', 'fhir-r5', 'opencrvs', 'semic',
  'schema-org', 'foaf', 'prov', 'dpv', 'dpv-consent-notice', 'icao',
].filter((sys) =>
  concepts.some((c) => Object.keys(c.external_equivalents ?? {}).includes(sys))
);
---

<Base title="Browse concepts" description="Filter and search all PublicSchema concepts by domain, maturity, abstract status, and system mappings.">
  <div class="faceted-page">
    <header class="page-header">
      <h1>Browse concepts</h1>
      <p class="intro">
        Explore all {totalCount} concepts in PublicSchema. Use the filters to narrow by domain,
        maturity, or external system mappings, or search by name and definition.
      </p>
    </header>

    <div class="layout">
      <!-- Facet panel -->
      <aside class="facet-panel">
        <details class="facet-drawer" open>
          <summary class="facet-drawer-toggle">Filters <span class="active-badge" id="active-count" aria-live="polite"></span></summary>

          <div class="facet-content">
            <button class="clear-btn" id="clear-all" type="button">Clear all</button>

            <!-- Domain -->
            <fieldset class="facet-group">
              <legend>Domain</legend>
              <label><input type="checkbox" name="domain" value="root"> Universal</label>
              <label><input type="checkbox" name="domain" value="sp"> sp (social protection)</label>
              <label><input type="checkbox" name="domain" value="crvs"> crvs (civil registration)</label>
            </fieldset>

            <!-- Maturity -->
            <fieldset class="facet-group">
              <legend>Maturity</legend>
              <label><input type="checkbox" name="maturity" value="draft"> Draft</label>
              <label><input type="checkbox" name="maturity" value="candidate"> Candidate</label>
              <label><input type="checkbox" name="maturity" value="normative"> Normative</label>
            </fieldset>

            <!-- Abstract -->
            <fieldset class="facet-group">
              <legend>Abstract</legend>
              <label><input type="checkbox" name="abstract" value="yes"> Yes</label>
              <label><input type="checkbox" name="abstract" value="no"> No</label>
            </fieldset>

            <!-- System mappings -->
            <fieldset class="facet-group">
              <legend>Has mapping in</legend>
              {allSystems.map((sys) => (
                <label><input type="checkbox" name="system" value={sys}> {sys}</label>
              ))}
            </fieldset>
          </div>
        </details>
      </aside>

      <!-- Results area -->
      <main class="results-area">
        <div class="results-toolbar">
          <div class="search-wrap">
            <label for="concept-search" class="sr-only">Search concepts</label>
            <input
              type="search"
              id="concept-search"
              placeholder="Search by name or definition..."
              autocomplete="off"
            />
          </div>
          <p class="result-count" id="result-count" aria-live="polite" aria-atomic="true">
            Showing {totalCount} of {totalCount}
          </p>
        </div>

        <div class="card-grid" id="card-grid">
          {concepts.map((c) => {
            const domainVal = c.domain ?? 'root';
            const systems = Object.keys(c.external_equivalents ?? {});
            const defSnippet = (c.definition?.en ?? '').replace(/\n/g, ' ').slice(0, 150);
            const defDisplay = defSnippet.length === 150 ? defSnippet + '…' : defSnippet;
            return (
              <a
                href={c.path.endsWith('/') ? c.path : c.path + '/'}
                class="concept-card"
                data-id={c.id.toLowerCase()}
                data-label={c.label.en.toLowerCase()}
                data-definition={(c.definition?.en ?? '').toLowerCase()}
                data-domain={domainVal}
                data-maturity={c.maturity}
                data-abstract={c.abstract ? 'yes' : 'no'}
                data-systems={systems.join(',')}
              >
                <div class="card-header">
                  <span class="concept-label">{c.label.en}</span>
                  <div class="badges">
                    {domainVal !== 'root' && (
                      <span class={`badge badge-domain badge-domain-${domainVal}`}>
                        {c.domain}
                      </span>
                    )}
                    <span class={`badge badge-maturity badge-maturity-${c.maturity}`}>
                      {c.maturity}
                    </span>
                    {c.abstract && <span class="badge badge-abstract">abstract</span>}
                  </div>
                </div>
                <p class="card-id">{c.id}</p>
                {defDisplay && <p class="card-def">{defDisplay}</p>}
                <div class="card-footer">
                  <span class="prop-count">{c.properties?.length ?? 0} properties</span>
                  {systems.length > 0 && (
                    <div class="system-chips">
                      {systems.map((sys) => (
                        <span class="chip">{sys}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>

        <p class="no-results" id="no-results" hidden>
          No concepts match the current filters. <button type="button" id="clear-all-2">Clear all filters</button>
        </p>
      </main>
    </div>
  </div>
</Base>

<style>
  /* ------------------------------------------------------------------ layout */
  .faceted-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    font-size: 1.8rem;
    margin: 0 0 0.4rem;
  }

  .intro {
    color: #555;
    margin: 0;
    max-width: 65ch;
  }

  .layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  /* ------------------------------------------------------------------ facet panel */
  .facet-panel {
    flex: 0 0 220px;
    min-width: 180px;
  }

  .facet-drawer {
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fafafa;
    overflow: hidden;
    position: sticky;
    top: 1rem;
  }

  .facet-drawer-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.9rem;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    list-style: none;
    background: #f0f0f0;
    border-bottom: 1px solid #ddd;
    user-select: none;
  }

  .facet-drawer-toggle::-webkit-details-marker { display: none; }

  .facet-content {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .clear-btn {
    font-size: 0.8rem;
    background: none;
    border: 1px solid #bbb;
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    align-self: flex-start;
    color: #444;
  }

  .clear-btn:hover { background: #eee; }

  .facet-group {
    border: none;
    padding: 0;
    margin: 0;
  }

  .facet-group legend {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #777;
    margin-bottom: 0.35rem;
  }

  .facet-group label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    padding: 0.1rem 0;
    cursor: pointer;
    color: #333;
  }

  .facet-group input[type="checkbox"] {
    accent-color: #2563eb;
    cursor: pointer;
  }

  .active-badge {
    background: #2563eb;
    color: #fff;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.05rem 0.4rem;
    min-width: 1.2rem;
    text-align: center;
  }

  .active-badge:empty { display: none; }

  /* ------------------------------------------------------------------ results */
  .results-area {
    flex: 1;
    min-width: 0;
  }

  .results-toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .search-wrap {
    flex: 1;
    min-width: 200px;
  }

  #concept-search {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 0.9rem;
    box-sizing: border-box;
  }

  #concept-search:focus {
    outline: 2px solid #2563eb;
    border-color: #2563eb;
  }

  .result-count {
    font-size: 0.85rem;
    color: #666;
    white-space: nowrap;
    margin: 0;
  }

  /* ------------------------------------------------------------------ cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.9rem;
  }

  .concept-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.9rem 1rem;
    border: 1px solid #dde;
    border-radius: 8px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .concept-card[hidden] { display: none; }

  .concept-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .concept-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: #111;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .badge-domain-root { background: #e5e7eb; color: #374151; }
  .badge-domain-sp   { background: #dbeafe; color: #1d4ed8; }
  .badge-domain-crvs { background: #ede9fe; color: #6d28d9; }

  .badge-maturity-draft     { background: #fef9c3; color: #854d0e; }
  .badge-maturity-candidate { background: #ffedd5; color: #9a3412; }
  .badge-maturity-normative { background: #dcfce7; color: #166534; }

  .badge-abstract { background: #f1f5f9; color: #475569; }

  .card-id {
    font-size: 0.75rem;
    color: #888;
    margin: 0;
    font-family: monospace;
  }

  .card-def {
    font-size: 0.82rem;
    color: #444;
    margin: 0;
    line-height: 1.45;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .prop-count {
    font-size: 0.75rem;
    color: #777;
    white-space: nowrap;
  }

  .system-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
  }

  .chip {
    font-size: 0.65rem;
    background: #f0f4ff;
    color: #3b5bdb;
    border: 1px solid #c5d0fa;
    border-radius: 3px;
    padding: 0.05rem 0.3rem;
    font-weight: 600;
    font-family: monospace;
  }

  .no-results {
    text-align: center;
    color: #777;
    margin-top: 3rem;
    font-size: 0.9rem;
  }

  .no-results button {
    background: none;
    border: none;
    color: #2563eb;
    cursor: pointer;
    text-decoration: underline;
    font-size: inherit;
  }

  /* ------------------------------------------------------------------ a11y */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ------------------------------------------------------------------ mobile */
  @media (max-width: 700px) {
    .layout {
      flex-direction: column;
    }

    .facet-panel {
      flex: unset;
      width: 100%;
    }

    .facet-drawer {
      position: static;
    }

    /* Collapse facets by default on mobile */
    .facet-drawer:not([open]) .facet-content {
      display: none;
    }
  }

  @media (min-width: 701px) {
    /* Always open on desktop — hide the toggle arrow cue */
    .facet-drawer-toggle {
      pointer-events: none;
    }
    .facet-drawer[open] > .facet-drawer-toggle::after {
      content: '';
    }
  }
</style>

<script>
  (() => {
    const grid = document.getElementById('card-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.concept-card'));
    const searchInput = document.getElementById('concept-search') as HTMLInputElement;
    const resultCountEl = document.getElementById('result-count')!;
    const activeCountEl = document.getElementById('active-count')!;
    const noResults = document.getElementById('no-results')!;
    const total = cards.length;

    // All checkbox groups
    const domainBoxes   = document.querySelectorAll<HTMLInputElement>('input[name="domain"]');
    const maturityBoxes = document.querySelectorAll<HTMLInputElement>('input[name="maturity"]');
    const abstractBoxes = document.querySelectorAll<HTMLInputElement>('input[name="abstract"]');
    const systemBoxes   = document.querySelectorAll<HTMLInputElement>('input[name="system"]');

    // -------------------------------------------------------- query-param helpers
    function getParam(key: string): string[] {
      return new URLSearchParams(location.search).getAll(key);
    }

    function buildQueryString(): string {
      const p = new URLSearchParams();
      domainBoxes.forEach((cb) => { if (cb.checked) p.append('domain', cb.value); });
      maturityBoxes.forEach((cb) => { if (cb.checked) p.append('maturity', cb.value); });
      abstractBoxes.forEach((cb) => { if (cb.checked) p.append('abstract', cb.value); });
      systemBoxes.forEach((cb) => { if (cb.checked) p.append('system', cb.value); });
      const q = searchInput.value.trim();
      if (q) p.set('q', q);
      return p.toString();
    }

    // -------------------------------------------------------- init from URL
    function initFromUrl() {
      const domains   = getParam('domain');
      const maturities = getParam('maturity');
      const abstracts  = getParam('abstract');
      const systems    = getParam('system');
      const q          = new URLSearchParams(location.search).get('q') ?? '';

      domainBoxes.forEach((cb) => { cb.checked = domains.includes(cb.value); });
      maturityBoxes.forEach((cb) => { cb.checked = maturities.includes(cb.value); });
      abstractBoxes.forEach((cb) => { cb.checked = abstracts.includes(cb.value); });
      systemBoxes.forEach((cb) => { cb.checked = systems.includes(cb.value); });
      searchInput.value = q;
    }

    // -------------------------------------------------------- filter logic
    function checkedValues(boxes: NodeListOf<HTMLInputElement>): string[] {
      return Array.from(boxes).filter((cb) => cb.checked).map((cb) => cb.value);
    }

    function applyFilters() {
      const domains   = checkedValues(domainBoxes);
      const maturities = checkedValues(maturityBoxes);
      const abstracts  = checkedValues(abstractBoxes);
      const systems    = checkedValues(systemBoxes);
      const query      = searchInput.value.trim().toLowerCase();

      let visible = 0;

      cards.forEach((card) => {
        const cardDomain   = card.dataset.domain!;
        const cardMaturity = card.dataset.maturity!;
        const cardAbstract = card.dataset.abstract!;
        const cardSystems  = card.dataset.systems ? card.dataset.systems.split(',') : [];

        const matchDomain   = domains.length === 0 || domains.includes(cardDomain);
        const matchMaturity = maturities.length === 0 || maturities.includes(cardMaturity);
        const matchAbstract = abstracts.length === 0 || abstracts.includes(cardAbstract);
        const matchSystem   = systems.length === 0 || systems.some((s) => cardSystems.includes(s));
        const matchQuery    = !query || [
          card.dataset.id ?? '',
          card.dataset.label ?? '',
          card.dataset.definition ?? '',
        ].some((field) => field.includes(query));

        const show = matchDomain && matchMaturity && matchAbstract && matchSystem && matchQuery;
        card.hidden = !show;
        if (show) visible++;
      });

      resultCountEl.textContent = `Showing ${visible} of ${total}`;
      noResults.hidden = visible > 0;

      // Active filter count
      const activeCount = domains.length + maturities.length + abstracts.length + systems.length + (query ? 1 : 0);
      activeCountEl.textContent = activeCount > 0 ? String(activeCount) : '';

      // Push to URL
      const qs = buildQueryString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    // -------------------------------------------------------- clear
    function clearAll() {
      domainBoxes.forEach((cb) => { cb.checked = false; });
      maturityBoxes.forEach((cb) => { cb.checked = false; });
      abstractBoxes.forEach((cb) => { cb.checked = false; });
      systemBoxes.forEach((cb) => { cb.checked = false; });
      searchInput.value = '';
      applyFilters();
    }

    document.getElementById('clear-all')!.addEventListener('click', clearAll);
    document.getElementById('clear-all-2')!.addEventListener('click', clearAll);

    // -------------------------------------------------------- event listeners
    domainBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    maturityBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    abstractBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    systemBoxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    searchInput.addEventListener('input', applyFilters);

    // -------------------------------------------------------- boot
    initFromUrl();
    applyFilters();
  })();
</script>
