---
import VocabDetail from '../../../components/pages/VocabDetail.astro';
import { loadVocabulary } from '../../../data/vocabulary';

export function getStaticPaths() {
  const vocab = loadVocabulary();
  return Object.keys(vocab.vocabularies).map((id) => ({ params: { vocab: id } }));
}
---
<VocabDetail vocab={Astro.params.vocab!} locale="fr" />
