---
import SystemDetail from '../../components/pages/SystemDetail.astro';
import { buildSystemIndex, listSystemsWithMatching, systemRegistry } from '../../data/systems';

export function getStaticPaths() {
  const index = buildSystemIndex();
  const ids = new Set([
    ...Object.keys(index),
    ...Object.keys(systemRegistry),
    ...listSystemsWithMatching(),
  ]);
  return Array.from(ids).map((id) => ({
    params: { system: id },
  }));
}
---
<SystemDetail system={Astro.params.system!} />
