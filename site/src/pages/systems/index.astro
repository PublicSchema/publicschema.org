---
import Base from "../../layouts/Base.astro";
import { buildSystemIndex, getSystemMeta } from "../../data/systems";

const index = buildSystemIndex();
const systems = Object.entries(index)
  .map(([id, entries]) => {
    const meta = getSystemMeta(id);
    const valueMapped = entries.filter((e) => e.relationship === "value_mapping").length;
    const sameStandard = entries.filter((e) => e.relationship === "same_standard").length;
    return { id, meta, entries, valueMapped, sameStandard, total: entries.length };
  })
  .sort((a, b) => b.total - a.total);
---
<Base title="Systems" description="External systems with vocabulary mappings to PublicSchema.">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="separator">/</span>Systems
    </nav>
    <h1>Systems</h1>
    <p class="subtitle">External systems and standards with vocabulary mappings to PublicSchema canonical values.</p>
  </div>

  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>System</th>
        <th>Vocabularies</th>
        <th>Value mappings</th>
        <th>Same standard</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {systems.map(({ id, meta, total, valueMapped, sameStandard }) => (
        <tr>
          <td><a href={`/systems/${id}`}>{meta.name}</a></td>
          <td data-label="Vocabularies">{total}</td>
          <td data-label="Value mappings">{valueMapped}</td>
          <td data-label="Same standard">{sameStandard}</td>
          <td data-label="Status">
            <span class={`badge badge-${meta.reviewStatus}`}>{meta.reviewStatus}</span>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
