---
import Base from "../../layouts/Base.astro";
import { loadVocabulary } from "../../data/vocabulary";
import type { Vocabulary } from "../../data/vocabulary";
import { getSystemName } from "../../data/systems";

export function getStaticPaths() {
  const vocab = loadVocabulary();
  return Object.keys(vocab.vocabularies).map((id) => ({ params: { vocab: id } }));
}

const allVocab = loadVocabulary();
const vocabulary = allVocab.vocabularies[Astro.params.vocab] as Vocabulary;
---
<Base title={vocabulary.id} description={vocabulary.definition.en} alternateJsonLd={`/vocab/${Astro.params.vocab}.jsonld`}>
  <article>
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="separator">/</span>
      <a href="/vocab/">Vocabularies</a>
      <span class="separator">/</span>
      {vocabulary.id}
    </nav>
    <h1>{vocabulary.id}</h1>
    <div class="meta-line">
      <span class={`badge badge-${vocabulary.maturity}`}>{vocabulary.maturity}</span>
    </div>
    <p class="definition-text">{vocabulary.definition.en}</p>
    <p class="uri">{vocabulary.uri}</p>
  </div>
  <div class="download-links">
    <a href={`/vocab/${Astro.params.vocab}.csv`} class="btn btn-secondary" download>CSV</a>
    <a href={`/vocab/${Astro.params.vocab}.jsonld`} class="btn btn-secondary">JSON-LD</a>
  </div>

  {vocabulary.standard && (
    <div class="concept-section">
      <h2>Standard reference</h2>
      <p>
        {vocabulary.standard.name}
        {vocabulary.standard.uri && (
          <> (<a href={vocabulary.standard.uri} target="_blank" rel="noopener">{vocabulary.standard.uri}</a>)</>
        )}
      </p>
      {vocabulary.standard.notes && (
        <p style="color: var(--color-text-muted); line-height: 1.65;">{vocabulary.standard.notes}</p>
      )}
    </div>
  )}

  {vocabulary.external_equivalents && Object.keys(vocabulary.external_equivalents).length > 0 && (
    <div class="concept-section">
      <h2>Aligned standards</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Standard</th>
            <th>Equivalent</th>
            <th>Match</th>
          </tr>
        </thead>
        <tbody>
          {Object.entries(vocabulary.external_equivalents).map(([key, eq]) => (
            <>
              <tr>
                <td>{eq.vocabulary}</td>
                <td><a href={eq.uri} target="_blank" rel="noopener">{eq.label}</a></td>
                <td><span class={`badge badge-${eq.match}`}>{eq.match.replace('_', ' ')}</span></td>
              </tr>
              {eq.note && (
                <tr class="aligned-note-row">
                  <td colspan="3" class="aligned-note">{eq.note}</td>
                </tr>
              )}
            </>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {vocabulary.external_values ? (
    <div class="concept-section">
      <h2>Values</h2>
      <p>
        This vocabulary is defined by an external standard{vocabulary.standard ? ` (${vocabulary.standard.name})` : ''}.
        The full list of values is available in the downloads above{vocabulary.standard?.uri ? (
          <> or from the <a href={vocabulary.standard.uri} target="_blank" rel="noopener">official standard page</a></>
        ) : ''}.
      </p>
    </div>
  ) : (
    <div class="concept-section">
      <h2>Values</h2>
      <table class="data-table mobile-card-table">
        <thead>
          <tr>
            <th>Code</th>
            <th>Label</th>
            <th>Standard code</th>
            <th>Definition</th>
          </tr>
        </thead>
        <tbody>
          {vocabulary.values.map((v) => (
            <tr>
              <td><code>{v.code}</code></td>
              <td data-label="Label">{v.label.en}</td>
              <td data-label="Standard code">{v.standard_code || ""}</td>
              <td data-label="Definition">{v.definition.en}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {vocabulary.same_standard_systems && vocabulary.same_standard_systems.length > 0 && (
    <div class="concept-section">
      <h2>Same standard</h2>
      <p>The following systems use the same underlying standard{vocabulary.standard ? ` (${vocabulary.standard.name})` : ''} for this vocabulary, so values are directly compatible without mapping:</p>
      <ul>
        {vocabulary.same_standard_systems.map((system) => (
          <li><a href={`/systems/${system}`}><strong>{getSystemName(system)}</strong></a></li>
        ))}
      </ul>
    </div>
  )}

  {vocabulary.system_mappings && Object.keys(vocabulary.system_mappings).length > 0 && (
    <div class="concept-section">
      <h2>System mappings</h2>
      {Object.entries(vocabulary.system_mappings).map(([system, mapping]) => (
        <div style="margin-bottom: var(--space-lg);">
          <h3><a href={`/systems/${system}`}>{getSystemName(system)}</a></h3>
          {mapping.vocabulary_name && (
            <p class="mapping-vocab-name">System vocabulary: <strong>{mapping.vocabulary_name}</strong></p>
          )}
          <table class="data-table">
            <thead>
              <tr>
                <th>System code</th>
                <th>System label</th>
                <th>{vocabulary.id} value</th>
              </tr>
            </thead>
            <tbody>
              {mapping.values.map((v) => (
                <tr class={v.maps_to === null ? 'unmapped-row' : ''}>
                  <td><code>{v.code}</code></td>
                  <td data-label="System label">{v.label}</td>
                  <td data-label={`${vocabulary.id} value`}>{v.maps_to ? (<code>{v.maps_to}</code>) : (<span class="no-mapping">{v.unmapped_reason ? v.unmapped_reason.replace(/_/g, " ") : "no equivalent"}</span>)}</td>
                </tr>
              ))}
            </tbody>
          </table>
          {mapping.unmapped_canonical && mapping.unmapped_canonical.length > 0 && (
            <p class="unmapped-note">
              Not covered by {getSystemName(system)}: {mapping.unmapped_canonical.map((code) => (<code>{code}</code>)).reduce((prev, curr) => <>{prev}, {curr}</>)}
            </p>
          )}
        </div>
      ))}
    </div>
  )}
  </article>
</Base>
