---
import Base from "../../layouts/Base.astro";
import { loadVocabulary } from "../../data/vocabulary";

const vocab = loadVocabulary();
const vocabularies = Object.values(vocab.vocabularies).sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="Vocabularies" description="Controlled value sets in the PublicSchema vocabulary.">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="separator">/</span>Vocabularies
    </nav>
    <h1>Vocabularies</h1>
    <p class="subtitle">Controlled value sets, referencing international standards where they exist.</p>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th>Vocabulary</th>
        <th>Values</th>
        <th>Standard</th>
        <th>Definition</th>
      </tr>
    </thead>
    <tbody>
      {vocabularies.map((v) => (
        <tr>
          <td><a href={`/vocab/${v.id}`}>{v.id}</a></td>
          <td>{v.values.length}</td>
          <td>{v.standard?.name || "None"}</td>
          <td>{v.definition.en?.slice(0, 80)}{(v.definition.en?.length || 0) > 80 ? "..." : ""}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
