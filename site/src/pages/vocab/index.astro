---
import Base from "../../layouts/Base.astro";
import { loadVocabulary } from "../../data/vocabulary";

const vocab = loadVocabulary();
const maturityRank: Record<string, number> = { normative: 0, "trial-use": 1, draft: 2 };
const vocabularies = Object.entries(vocab.vocabularies)
  .map(([key, v]) => ({ key, ...v }))
  .sort((a, b) =>
    (maturityRank[a.maturity] ?? 9) - (maturityRank[b.maturity] ?? 9) || a.key.localeCompare(b.key)
  );
---
<Base title="Vocabularies" description="Controlled value sets in the PublicSchema vocabulary.">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="separator">/</span>Vocabularies
    </nav>
    <h1>Vocabularies</h1>
    <p class="subtitle">Controlled value sets, referencing international standards where they exist.</p>
  </div>

  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>Vocabulary</th>
        <th>Values</th>
        <th>Standard</th>
        <th>Definition</th>
      </tr>
    </thead>
    <tbody>
      {vocabularies.map((v) => (
        <tr>
          <td><a href={`/vocab/${v.key}`}>{v.key}</a></td>
          <td data-label="Values">{v.values.length}</td>
          <td data-label="Standard">{v.standard?.name || "None"}</td>
          <td data-label="Definition">{v.definition.en?.slice(0, 80)}{(v.definition.en?.length || 0) > 80 ? "..." : ""}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
