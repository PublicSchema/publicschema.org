---
/**
 * Catch-all route for concepts and properties.
 * Concepts: /Person (universal), /sp/Enrollment (domain-specific)
 * Properties: /date_of_birth (universal), /sp/enrollment_status (domain-specific)
 */
import Base from "../layouts/Base.astro";
import { loadVocabulary } from "../data/vocabulary";
import type { Concept, Property } from "../data/vocabulary";
import { getSystemName } from "../data/systems";

export function getStaticPaths() {
  const vocab = loadVocabulary();
  const paths = [];

  for (const [id, concept] of Object.entries(vocab.concepts)) {
    const slug = concept.path.replace(/^\//, "");
    paths.push({ params: { slug }, props: { kind: "concept" as const, termId: id } });
  }
  for (const [id, prop] of Object.entries(vocab.properties)) {
    const slug = prop.path.replace(/^\//, "");
    paths.push({ params: { slug }, props: { kind: "property" as const, termId: id } });
  }

  return paths;
}

const vocab = loadVocabulary();
const { kind, termId } = Astro.props;

/** Look up a concept's path by ID for linking. */
function conceptPath(id: string): string {
  return vocab.concepts[id]?.path || `/${id}`;
}

/** Look up a property's path by ID for linking. */
function propPath(id: string): string {
  return vocab.properties[id]?.path || `/${id}`;
}

/** Recursively collect inherited properties from the full supertype chain.
 *  Each property is attributed to the nearest ancestor that declares it. */
function collectInheritedProperties(
  conceptId: string,
  seenIds: Set<string>,
  visited: Set<string> = new Set(),
): Array<{id: string; detail: typeof vocab.properties[string] | undefined; from: string}> {
  const result: Array<{id: string; detail: typeof vocab.properties[string] | undefined; from: string}> = [];
  const concept = vocab.concepts[conceptId];
  if (!concept) return result;
  for (const st of concept.supertypes) {
    if (visited.has(st)) continue;
    visited.add(st);
    const parent = vocab.concepts[st];
    if (!parent) continue;
    for (const ref of parent.properties) {
      if (!seenIds.has(ref.id)) {
        seenIds.add(ref.id);
        result.push({ ...ref, detail: vocab.properties[ref.id], from: st });
      }
    }
    result.push(...collectInheritedProperties(st, seenIds, visited));
  }
  return result;
}

/** Recursively collect all subtypes (direct and indirect) of a concept, flat. */
function collectAllSubtypes(conceptId: string): string[] {
  const result: string[] = [];
  const visited = new Set<string>();
  function walk(id: string) {
    if (visited.has(id)) return;
    visited.add(id);
    const c = vocab.concepts[id];
    if (!c) return;
    for (const st of c.subtypes) {
      result.push(st);
      walk(st);
    }
  }
  walk(conceptId);
  return result;
}


---

{kind === "concept" ? (() => {
  const concept = vocab.concepts[termId] as Concept;
  const propList = concept.properties.map((ref) => ({
    ...ref,
    detail: vocab.properties[ref.id],
  }));
  return (
    <Base title={concept.id} description={concept.definition.en} alternateJsonLd={`${concept.path}.jsonld`}>
      <article>
      <div class="page-header">
        <nav class="breadcrumb">
          <a href="/">Home</a>
          <span class="separator">/</span>
          <a href="/concepts/">Concepts</a>
          <span class="separator">/</span>
          {concept.id}
        </nav>
        <h1>{concept.domain && <span class="domain-prefix" title={{"sp": "Social Protection"}[concept.domain] || concept.domain}>{concept.domain}:</span>}{concept.id}</h1>
        <div class="meta-line">
          <span class={`badge badge-${concept.maturity}`}>{concept.maturity}</span>
        </div>
        <p class="definition-text">{concept.definition.en}</p>
        <p class="uri">{concept.uri}</p>
      </div>
      <div class="download-links">
        <a href={`${concept.path}.jsonld`} class="btn btn-secondary">JSON-LD</a>
        <a href={`${concept.path}.csv`} class="btn btn-secondary" download>CSV</a>
        <a href={`${concept.path}-definition.xlsx`} class="btn btn-secondary" download>Definition (Excel)</a>
        <a href={`${concept.path}-template.xlsx`} class="btn btn-secondary" download>Template (Excel)</a>
      </div>

      {concept.external_equivalents && Object.keys(concept.external_equivalents).length > 0 && (
        <div class="concept-section">
          <h2>Aligned standards</h2>
          <table class="data-table">
            <thead>
              <tr>
                <th>Standard</th>
                <th>Equivalent</th>
                <th>Match</th>
              </tr>
            </thead>
            <tbody>
              {Object.entries(concept.external_equivalents).map(([key, eq]) => (
                <>
                  <tr>
                    <td>{eq.vocabulary}</td>
                    <td><a href={eq.uri} target="_blank" rel="noopener">{eq.label}</a></td>
                    <td><span class={`badge badge-${eq.match}`}>{eq.match.replace('_', ' ')}</span></td>
                  </tr>
                  {eq.note && (
                    <tr class="aligned-note-row">
                      <td colspan="3" class="aligned-note">{eq.note}</td>
                    </tr>
                  )}
                </>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {concept.supertypes.length > 0 && (
        <div class="concept-section">
          <h2>Supertypes</h2>
          <div class="type-links">
            {concept.supertypes.map((s) => <a href={conceptPath(s)}>{s}</a>)}
          </div>
        </div>
      )}

      {concept.subtypes.length > 0 && (() => {
        function renderSubtypes(parentId: string, isRoot: boolean): any {
          const c = vocab.concepts[parentId];
          if (!c || c.subtypes.length === 0) return null;
          return c.subtypes.map((st, i) => {
            const children = vocab.concepts[st]?.subtypes || [];
            if (isRoot) {
              return (
                <span class="subtype-entry">
                  <a href={conceptPath(st)}>{st}</a>
                  {children.length > 0 && <span class="subtype-children">{renderSubtypes(st, false)}</span>}
                </span>
              );
            }
            return <>{i > 0 && ", "}<a href={conceptPath(st)}>{st}</a></>;
          });
        }
        return (
          <div class="concept-section">
            <h2>Subtypes</h2>
            <div class="subtype-list">
              {renderSubtypes(termId, true)}
            </div>
          </div>
        );
      })()}

      {(() => {
        const ownIds = new Set(concept.properties.map((ref) => ref.id));
        const inheritedProps = collectInheritedProperties(termId, new Set(ownIds));
        const allProps = [
          ...propList.map((p) => ({ ...p, from: null as string | null })),
          ...inheritedProps,
        ].sort((a, b) => a.id.localeCompare(b.id));
        return (
          <div class="concept-section">
            <h2>Properties</h2>
            {allProps.length > 0 ? (
              <table class="data-table mobile-card-table">
                <thead>
                  <tr>
                    <th>Property</th>
                    <th>Type</th>
                    <th>Definition</th>
                  </tr>
                </thead>
                <tbody>
                  {allProps.map((p) => {
                    const typeStr = p.detail?.type || "unknown";
                    const conceptRef = typeStr.match(/^concept:(.+)$/)?.[1];
                    const primitives = ["string", "integer", "decimal", "boolean", "date", "datetime", "uri", "geojson_geometry"];
                    const isPrimitive = primitives.includes(typeStr);
                    return (
                      <tr class={p.from ? "inherited-row" : ""}>
                        <td>
                          <a href={propPath(p.id)}>{p.id}</a>
                          {p.from && <span class="inherited-badge">from <a href={conceptPath(p.from)}>{p.from}</a></span>}
                        </td>
                        <td data-label="Type">
                          {conceptRef
                            ? <a href={conceptPath(conceptRef)}><code>{typeStr}</code></a>
                            : isPrimitive
                              ? <a href={`/types#${typeStr}`}><code>{typeStr}</code></a>
                              : <code>{typeStr}</code>
                          }
                          {conceptRef && (() => {
                            const subs = collectAllSubtypes(conceptRef);
                            return subs.length > 0 && (
                              <span class="subtype-hint">
                                includes {subs.map((s, i) => <>{i > 0 && ", "}<a href={conceptPath(s)}>{s}</a></>)}
                              </span>
                            );
                          })()}
                          {p.detail?.vocabulary && (
                            <> (<a href={`/vocab/${p.detail.vocabulary}`}>{p.detail.vocabulary}</a>)</>
                          )}
                        </td>
                        <td data-label="Definition">{p.detail?.definition.en?.slice(0, 80)}{(p.detail?.definition.en?.length || 0) > 80 ? "..." : ""}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            ) : (
              <p style="color: var(--color-text-muted);">No properties defined yet.</p>
            )}
          </div>
        );
      })()}

      </article>
    </Base>
  );
})() : (() => {
  const prop = vocab.properties[termId] as Property;
  const typeConceptRef = prop.type.match(/^concept:(.+)$/)?.[1];
  const primitiveTypes = ["string", "integer", "decimal", "boolean", "date", "datetime", "uri", "geojson_geometry"];
  const isPrimitiveType = primitiveTypes.includes(prop.type);
  return (
    <Base title={prop.id} description={prop.definition.en} alternateJsonLd={`${prop.path}.jsonld`}>
      <article>
      <div class="page-header">
        <nav class="breadcrumb">
          <a href="/">Home</a>
          <span class="separator">/</span>
          <a href="/properties/">Properties</a>
          <span class="separator">/</span>
          {prop.id}
        </nav>
        <h1>{prop.id}</h1>
        <div class="meta-line">
          <span class={`badge badge-${prop.maturity}`}>{prop.maturity}</span>
          {prop.sensitivity && prop.sensitivity !== "standard" && (
            <span class={`badge badge-${prop.sensitivity}`}>{prop.sensitivity}</span>
          )}
        </div>
        <p class="definition-text">{prop.definition.en}</p>
        <p class="uri">{prop.uri}</p>
      </div>
      <div class="download-links">
        <a href={`${prop.path}.jsonld`} class="btn btn-secondary">JSON-LD</a>
      </div>

      {prop.external_equivalents && Object.keys(prop.external_equivalents).length > 0 && (
        <div class="concept-section">
          <h2>Aligned standards</h2>
          <table class="data-table">
            <thead>
              <tr>
                <th>Standard</th>
                <th>Equivalent</th>
                <th>Match</th>
              </tr>
            </thead>
            <tbody>
              {Object.entries(prop.external_equivalents).map(([key, eq]) => (
                <>
                  <tr>
                    <td>{eq.vocabulary}</td>
                    <td><a href={eq.uri} target="_blank" rel="noopener">{eq.label}</a></td>
                    <td><span class={`badge badge-${eq.match}`}>{eq.match.replace('_', ' ')}</span></td>
                  </tr>
                  {eq.note && (
                    <tr class="aligned-note-row">
                      <td colspan="3" class="aligned-note">{eq.note}</td>
                    </tr>
                  )}
                </>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <div class="concept-section">
        <h2>Details</h2>
        <table class="data-table detail-kv-table">
          <tbody>
            <tr>
              <td style="font-weight: 600; color: var(--color-text-muted); width: 10rem;">Type</td>
              <td>
                {typeConceptRef
                  ? <a href={conceptPath(typeConceptRef)}><code>{prop.type}</code></a>
                  : isPrimitiveType
                    ? <a href={`/types#${prop.type}`}><code>{prop.type}</code></a>
                    : <code>{prop.type}</code>
                }
                {typeConceptRef && (() => {
                  const subs = collectAllSubtypes(typeConceptRef);
                  return subs.length > 0 && (
                    <span class="subtype-hint">
                      includes {subs.map((s, i) => <>{i > 0 && ", "}<a href={conceptPath(s)}>{s}</a></>)}
                    </span>
                  );
                })()}
              </td>
            </tr>
            <tr>
              <td style="font-weight: 600; color: var(--color-text-muted);">Cardinality</td>
              <td>{prop.cardinality}</td>
            </tr>
            {prop.vocabulary && (
              <tr>
                <td style="font-weight: 600; color: var(--color-text-muted);">Vocabulary</td>
                <td><a href={`/vocab/${prop.vocabulary}`}>{prop.vocabulary}</a></td>
              </tr>
            )}
            {prop.references && (
              <tr>
                <td style="font-weight: 600; color: var(--color-text-muted);">References</td>
                <td>
                  <a href={conceptPath(prop.references)}>{prop.references}</a>
                  {(() => {
                    const subs = collectAllSubtypes(prop.references);
                    return subs.length > 0 && (
                      <span class="subtype-hint">
                        includes {subs.map((s, i) => <>{i > 0 && ", "}<a href={conceptPath(s)}>{s}</a></>)}
                      </span>
                    );
                  })()}
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      <div class="concept-section">
        <h2>Used by</h2>
        {prop.used_by.length > 0 ? (
          <div class="type-links">
            {prop.used_by.map((d) => <a href={conceptPath(d)}>{d}</a>)}
          </div>
        ) : (
          <p style="color: var(--color-text-muted);">Not used by any concept yet.</p>
        )}
      </div>

      {prop.system_mappings && Object.keys(prop.system_mappings).length > 0 && (
        <div class="concept-section">
          <h2>System mappings</h2>
          {Object.entries(prop.system_mappings).map(([system, mapping]) => (
            <div style="margin-bottom: var(--space-lg);">
              <h3><a href={`/systems/${system}`}>{getSystemName(system)}</a></h3>
              {mapping.vocabulary_name && (
                <p class="mapping-vocab-name">System vocabulary: <strong>{mapping.vocabulary_name}</strong></p>
              )}
              <table class="data-table">
                <thead>
                  <tr>
                    <th>System code</th>
                    <th>System label</th>
                    <th>{prop.id} value</th>
                  </tr>
                </thead>
                <tbody>
                  {mapping.values.map((v) => (
                    <tr class={v.maps_to === null ? 'unmapped-row' : ''}>
                      <td><code>{v.code}</code></td>
                      <td data-label="System label">{v.label}</td>
                      <td data-label={`${prop.id} value`}>
                        {v.maps_to !== null
                          ? (<code>{v.maps_to}</code>)
                          : (<span class="no-mapping">{v.unmapped_reason?.replace(/_/g, " ") ?? "no equivalent"}</span>)
                        }
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              {mapping.unmapped_canonical && mapping.unmapped_canonical.length > 0 && (
                <p class="unmapped-note">
                  Not covered by {getSystemName(system)}: {mapping.unmapped_canonical.map((code, i) => (
                    <>{i > 0 && ", "}<code>{code}</code></>
                  ))}
                </p>
              )}
            </div>
          ))}
        </div>
      )}

      </article>
    </Base>
  );
})()}
