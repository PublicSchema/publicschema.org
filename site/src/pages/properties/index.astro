---
import Base from "../../layouts/Base.astro";
import { loadVocabulary } from "../../data/vocabulary";

const vocab = loadVocabulary();
const properties = Object.values(vocab.properties).sort((a, b) => a.id.localeCompare(b.id));
const primitiveTypes = ["string", "integer", "decimal", "boolean", "date"];
---
<Base title="Properties" description="All properties in the PublicSchema vocabulary.">
  <div class="page-header">
    <nav class="breadcrumb">
      <a href="/">Home</a><span class="separator">/</span>Properties
    </nav>
    <h1>Properties</h1>
    <p class="subtitle">Reusable attributes shared across concepts.</p>
  </div>

  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>Property</th>
        <th>Type</th>
        <th>Used by</th>
      </tr>
    </thead>
    <tbody>
      {properties.map((p) => {
        const conceptRef = p.type.match(/^concept:(.+)$/)?.[1];
        const isPrimitive = primitiveTypes.includes(p.type);
        return (
          <tr>
            <td><a href={p.path}>{p.id}</a></td>
            <td data-label="Type">{conceptRef
              ? <a href={vocab.concepts[conceptRef]?.path || `/${conceptRef}`}><code>{p.type}</code></a>
              : isPrimitive
                ? <a href={`/types#${p.type}`}><code>{p.type}</code></a>
                : <code>{p.type}</code>
            }</td>
            <td data-label="Used by">{p.used_by.join(", ")}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</Base>
